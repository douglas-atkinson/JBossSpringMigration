<module name="org.jboss.narayana.lra.lra-participant" xmlns="urn:jboss:module:1.9">

  <properties>
    <property name="jboss.api" value="private"/>
  </properties>
  <resources>
    <resource-root path="lra-client-1.1.0.Final.jar"/>
    <resource-root path="lra-proxy-api-1.1.0.Final.jar"/>
    <resource-root path="narayana-lra-1.1.0.Final.jar"/>
  </resources>

  <dependencies>
    <module name="org.eclipse.microprofile.lra.api"/>
    <module name="org.jboss.modules"/>
    <module name="org.jboss.logging"/>
    <module name="jakarta.ws.rs.api"/>
    <module name="org.jboss.narayana.lra.lra-service-base"/>

    <!-- lra-client -->
<!--     org.eclipse.microprofile.restclient stands for microprofile-rest-client-api -->
    <module name="org.eclipse.microprofile.restclient"/>
    <module name="org.jboss.resteasy.resteasy-client-microprofile"/>
    <module name="org.jboss.resteasy.resteasy-client"/>
    <module name="jakarta.enterprise.api"/>
    <!-- Setting the cuncurrent.api optional prevents it being provisioned in a slimmed server whose provisioning config doesn't include the actual Jakarta Concurrency integration -->
    <module name="jakarta.enterprise.concurrent.api" optional="true"/>

    <!-- lra-proxy-api -->
    <module name="io.smallrye.jandex"/>
    <!-- narayana-lra -->
    <module name="org.eclipse.microprofile.config.api"/>
    <module name="io.smallrye.config"/>
    <module name="io.smallrye.stork"/>

    <!-- Required for proper creation of proxies for CDI beans originating from this module -->    
    <module name="org.jboss.weld.api"/>
    <module name="org.jboss.weld.core"/>
    <module name="org.jboss.weld.spi"/>

  </dependencies>
</module>
