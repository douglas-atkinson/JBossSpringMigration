<!-- Standalone (RESOURCE_LOCAL) persistence unit for MemberRepositoryTest. Unlike
     src/main/resources/META-INF/persistence.xml, this bootstraps directly against an in-memory
     H2 database via JDBC - no application server, JTA, or JNDI datasource involved - so the test
     can run under plain JUnit 5 without a container. Named distinctly from "primary" so both
     persistence.xml files can coexist on the test classpath without a naming collision. -->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
   <persistence-unit name="kitchensinkTest" transaction-type="RESOURCE_LOCAL">
      <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
      <class>org.jboss.as.quickstarts.kitchensink.model.Member</class>
      <exclude-unlisted-classes>true</exclude-unlisted-classes>
      <properties>
         <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver" />
         <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:kitchensink-standalone-test;DB_CLOSE_DELAY=-1" />
         <property name="jakarta.persistence.jdbc.user" value="sa" />
         <property name="jakarta.persistence.jdbc.password" value="sa" />
         <property name="hibernate.hbm2ddl.auto" value="create-drop" />
         <property name="hibernate.show_sql" value="false" />
      </properties>
   </persistence-unit>
</persistence>
